# Config for `docker compose up` (compose.yaml) — the one-command way to run
# the whole app (frontend + backend + MongoDB + Redis).
#
# Setup: cp .env.example .env, then fill in the two API keys below if you
# want code execution / AI chat to work. Everything else already has a
# working default for the bundled containers.
#
# (This is separate from backend/.env / frontend/.env — those are for running
# the frontend/backend directly with `npm run dev`, outside Docker. If you're
# using `docker compose up`, this is the only .env file you need.)

# ─── Required ──────────────────────────────────────────────────────────────

# Signs/verifies JWTs for both REST auth and the Socket.io handshake — must
# be a long random string. Compose will refuse to start the backend if this
# is left unset. This is local dev only; never reuse a value like this for a
# real deployment.
JWT_SECRET=change_this_to_a_long_random_string_like_devcollab_super_secret_2026

# ─── Optional — features degrade gracefully without these ─────────────────

# Judge0 (Run Code button). Without it, /api/v1/rooms/execute returns a
# friendly 503 instead of running anything. Get a free key at
# rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_KEY=

# Google Gemini (AI pair programmer chat). Without it, the AI panel returns a
# friendly 503 instead of answering. Get a free key at aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Already correct for `docker compose up` — only change these if you're ──
# ─── pointing at an external database instead of the bundled containers  ───

# Bundled mongo container, reachable by Compose's internal DNS as "mongo".
# Point this at a MongoDB Atlas connection string instead if you'd rather use
# a real cluster than the local container (e.g.
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/devcollab).
MONGODB_URI=mongodb://mongo:27017/devcollab

# Bundled redis container, reachable by Compose's internal DNS as "redis".
# Only load-bearing once you run more than one backend instance (see
# docker-compose.yml, the separate multi-instance test rig) — with the single
# backend instance compose.yaml runs, this is here for parity with the real
# deploy topology, not because anything breaks without it.
REDIS_URL=redis://redis:6379
