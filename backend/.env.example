PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/devcollab?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string_like_devcollab_super_secret_2025
CLIENT_URL=http://localhost:5173

# Optional. Only needed when running more than one backend instance (see
# docker-compose.yml) — lets Socket.io broadcasts reach sockets connected to a
# different instance. Leave unset for normal single-instance local dev; the
# server falls back to Socket.io's default in-memory adapter.
REDIS_URL=

# Judge0 (code execution) — get a key at rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_KEY=

# Google Gemini (AI pair programmer) — get your key at aistudio.google.com/apikey
GEMINI_API_KEY=
